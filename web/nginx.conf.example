# ResearchVault VPS 用 nginx 設定例
# /etc/nginx/sites-available/researchvault などに配置し、
# 下記の upstream ポートを server.js の PORT に合わせること。

upstream researchvault_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name rv.insas.jp;

    # Let's Encrypt 等で TLS を終端する場合は 443 ブロックを追加

    client_max_body_size 20m;

    location /api/ {
        proxy_pass http://researchvault_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location / {
        proxy_pass http://researchvault_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
